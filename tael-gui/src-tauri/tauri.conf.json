{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tael",
  "version": "0.5.6",
  "identifier": "inc.thousandbirds.tael",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tael",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}
