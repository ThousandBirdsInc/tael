[0.5, "o", "\r\n\u001b[1;36m# Long-running signals and self diagnostics stay trace-linked too.\u001b[0m\r\n"]
[0.18, "o", "\u001b[1;32m>\u001b[0m tael signal create --from-trace 11352dea5f3e... --name payment_declined --failure-mode payment_declined\r\n"]
[0.35, "o", ""]
[0.6, "o", "Signal signal_ca0a52bd1c2a41c8837030e9cd433b4a (payment_declined) added to trace 11352dea5f3ecd0cfd2df94df71fea6f\r\n"]
[0.18, "o", "\u001b[1;32m>\u001b[0m tael diagnose report --trace-id 11352dea5f3e... --category missing_context --severity low --confidence low --summary \"Agent should check payment error taxonomy before escalating\"\r\n"]
