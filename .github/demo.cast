[2.0, "o", "\r\n\u001b[1;36m# \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\r\n\r\n  \u001b[1;37mtael\u001b[0m \u2014 observability built for AI agents\r\n\r\n  \u001b[0;90m\u2022 Single binary: `tael serve` is server + client + storage\u001b[0m\r\n  \u001b[0;90m\u2022 OTLP traces, logs & metrics + Prometheus remote-write\u001b[0m\r\n  \u001b[0;90m\u2022 Tiered storage engine (hot\u2192warm\u2192cold) \u2014 no external deps\u001b[0m\r\n  \u001b[0;90m\u2022 Typed LLM spans (gen_ai.*): model/token/cost + payload search\u001b[0m\r\n  \u001b[0;90m\u2022 summarize \u00b7 anomalies \u00b7 correlate \u2014 agent-ready analysis\u001b[0m\r\n  \u001b[0;90m\u2022 Read-only SQL over the telemetry tables\u001b[0m\r\n  \u001b[0;90m\u2022 `tael live` TUI: waterfall + fullscreen span viewer\u001b[0m\r\n"]
